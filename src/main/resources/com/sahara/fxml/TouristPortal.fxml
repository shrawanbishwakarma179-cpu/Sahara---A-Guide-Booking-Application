<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sahara.controller.TouristPortalController"
            style="-fx-background-color: #1a1a2e;">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: #16213e; -fx-padding: 14 20 14 20;">
            <Label text="🏔 SAHARA" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" style="-fx-text-fill: white; -fx-font-size: 13px;"/>
            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 6 14;"/>
        </HBox>
    </top>

    <!-- TABS -->
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE"
                 style="-fx-background-color: #1a1a2e; -fx-tab-min-width: 140px;">

            <!-- ====== BROWSE TOURS ====== -->
            <Tab text="Browse Tours">
                <VBox spacing="12" style="-fx-padding: 20; -fx-background-color: #1a1a2e;">
                    <Label text="Available Tour Packages"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <TableView fx:id="toursTable" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: #16213e; -fx-table-cell-border-color: #0f3460;">
                        <columns>
                            <TableColumn fx:id="colTourId"   text="ID"       prefWidth="70"/>
                            <TableColumn fx:id="colTourName" text="Package"  prefWidth="220"/>
                            <TableColumn fx:id="colDuration" text="Duration" prefWidth="120"/>
                            <TableColumn fx:id="colPrice"    text="Price ($)" prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <!-- ====== BOOK A TOUR ====== -->
            <Tab text="Book a Tour">
                <VBox spacing="16" style="-fx-padding: 24; -fx-background-color: #1a1a2e;">
                    <Label text="New Booking"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>

                    <GridPane hgap="20" vgap="12">
                        <columnConstraints>
                            <ColumnConstraints prefWidth="160" halignment="RIGHT"/>
                            <ColumnConstraints prefWidth="300" hgrow="ALWAYS"/>
                        </columnConstraints>

                        <Label text="Select Guide:" style="-fx-text-fill: #a0a0c0;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="guideCombo" maxWidth="Infinity" GridPane.rowIndex="0" GridPane.columnIndex="1"
                                  style="-fx-background-color: #0f3460; -fx-text-fill: white;"/>

                        <Label text="Booking Date:" style="-fx-text-fill: #a0a0c0;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <DatePicker fx:id="bookingDatePicker" maxWidth="Infinity" GridPane.rowIndex="1" GridPane.columnIndex="1"
                                    style="-fx-background-color: #0f3460;"/>

                        <Label text="Payment Method:" style="-fx-text-fill: #a0a0c0;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="paymentCombo" maxWidth="Infinity" GridPane.rowIndex="2" GridPane.columnIndex="1"
                                  style="-fx-background-color: #0f3460; -fx-text-fill: white;"/>

                        <Label text="Select Tours\n(Ctrl+Click multi):" style="-fx-text-fill: #a0a0c0;" GridPane.rowIndex="3" GridPane.columnIndex="0" GridPane.valignment="TOP"/>
                        <ListView fx:id="tourSelectList" prefHeight="140" GridPane.rowIndex="3" GridPane.columnIndex="1"
                                  style="-fx-background-color: #0f3460; -fx-text-fill: white;"/>
                    </GridPane>

                    <Label fx:id="bookingStatus" text="" style="-fx-text-fill: #e94560;"/>

                    <Button text="BOOK NOW" onAction="#handleBookNow"
                            style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-font-weight: bold;
                                   -fx-font-size: 14px; -fx-background-radius: 6; -fx-padding: 10 30;"/>
                </VBox>
            </Tab>

            <!-- ====== MY BOOKINGS ====== -->
            <Tab text="My Bookings">
                <VBox spacing="12" style="-fx-padding: 20; -fx-background-color: #1a1a2e;">
                    <Label text="My Booking History"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <TableView fx:id="myBookingsTable" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: #16213e;">
                        <columns>
                            <TableColumn fx:id="colBId"      text="ID"      prefWidth="60"/>
                            <TableColumn fx:id="colBGuide"   text="Guide"   prefWidth="160"/>
                            <TableColumn fx:id="colBDate"    text="Date"    prefWidth="120"/>
                            <TableColumn fx:id="colBStatus"  text="Status"  prefWidth="120"/>
                            <TableColumn fx:id="colBPayment" text="Payment" prefWidth="120"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <!-- ====== FEEDBACK ====== -->
            <Tab text="Give Feedback">
                <VBox spacing="16" style="-fx-padding: 24; -fx-background-color: #1a1a2e;">
                    <Label text="Rate Your Guide"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>

                    <GridPane hgap="20" vgap="12">
                        <columnConstraints>
                            <ColumnConstraints prefWidth="160" halignment="RIGHT"/>
                            <ColumnConstraints prefWidth="300" hgrow="ALWAYS"/>
                        </columnConstraints>

                        <Label text="Select Booking:" style="-fx-text-fill: #a0a0c0;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="feedbackBookingCombo" maxWidth="Infinity" GridPane.rowIndex="0" GridPane.columnIndex="1"
                                  style="-fx-background-color: #0f3460; -fx-text-fill: white;"/>

                        <Label text="Rating (1-5):" style="-fx-text-fill: #a0a0c0;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <Spinner fx:id="ratingSpinner" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="80"
                                 style="-fx-background-color: #0f3460;"/>

                        <Label text="Comment:" style="-fx-text-fill: #a0a0c0;" GridPane.rowIndex="2" GridPane.columnIndex="0" GridPane.valignment="TOP"/>
                        <TextArea fx:id="commentArea" prefHeight="100" GridPane.rowIndex="2" GridPane.columnIndex="1"
                                  promptText="Share your experience..."
                                  style="-fx-background-color: #0f3460; -fx-text-fill: white; -fx-prompt-text-fill: #606080;"/>
                    </GridPane>

                    <Label fx:id="feedbackStatus" text="" style="-fx-text-fill: #4caf50;"/>

                    <Button text="SUBMIT FEEDBACK" onAction="#handleSubmitFeedback"
                            style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-font-weight: bold;
                                   -fx-font-size: 14px; -fx-background-radius: 6; -fx-padding: 10 30;"/>
                </VBox>
            </Tab>

        </TabPane>
    </center>
</BorderPane>
