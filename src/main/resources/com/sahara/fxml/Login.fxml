<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.sahara.controller.LoginController"
           style="-fx-background-color: #1a1a2e;">

    <VBox alignment="CENTER" spacing="20" maxWidth="400">
        <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

        <!-- Logo / Title -->
        <VBox alignment="CENTER" spacing="4">
            <Label text="SAHARA" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>
            <Label text="A Guide Booking System" style="-fx-font-size: 13px; -fx-text-fill: #a0a0c0;"/>
        </VBox>

        <!-- Card -->
        <VBox spacing="14" style="-fx-background-color: #16213e; -fx-background-radius: 12; -fx-padding: 30;">

            <Label text="Sign In" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>

            <VBox spacing="4">
                <Label text="Role" style="-fx-text-fill: #a0a0c0; -fx-font-size: 12px;"/>
                <ComboBox fx:id="roleCombo" maxWidth="Infinity"
                          style="-fx-background-color: #0f3460; -fx-text-fill: white; -fx-border-color: #e94560; -fx-border-radius: 6; -fx-background-radius: 6;"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Email" style="-fx-text-fill: #a0a0c0; -fx-font-size: 12px;"/>
                <TextField fx:id="emailField" promptText="Enter your email"
                           style="-fx-background-color: #0f3460; -fx-text-fill: white; -fx-prompt-text-fill: #606080; -fx-border-color: #e94560; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8;"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Password" style="-fx-text-fill: #a0a0c0; -fx-font-size: 12px;"/>
                <PasswordField fx:id="passwordField" promptText="Enter your password"
                               style="-fx-background-color: #0f3460; -fx-text-fill: white; -fx-prompt-text-fill: #606080; -fx-border-color: #e94560; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8;"/>
            </VBox>

            <Label fx:id="statusLabel" text="" style="-fx-text-fill: #e94560; -fx-font-size: 12px;"/>

            <Button text="LOGIN" onAction="#handleLogin" maxWidth="Infinity"
                    style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 6; -fx-padding: 10;"/>

            <Separator style="-fx-background-color: #0f3460;"/>

            <HBox alignment="CENTER" spacing="8">
                <Label text="Don't have an account?" style="-fx-text-fill: #a0a0c0; -fx-font-size: 12px;"/>
                <Button text="Register" onAction="#handleRegister"
                        style="-fx-background-color: transparent; -fx-text-fill: #e94560; -fx-font-size: 12px; -fx-underline: true; -fx-cursor: hand; -fx-border-color: transparent;"/>
            </HBox>
        </VBox>

        <Label text="University of Bedfordshire | CIS096-1" style="-fx-text-fill: #606080; -fx-font-size: 10px;"/>
    </VBox>
</StackPane>
